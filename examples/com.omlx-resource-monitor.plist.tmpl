<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  omlx-resource-monitor LaunchAgent template.

  install.sh substitutes __PYTHON_BIN__ and __INSTALL_DIR__ at install time
  and copies the result to ~/Library/LaunchAgents/com.omlx-resource-monitor.plist.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.omlx-resource-monitor</string>

  <key>ProgramArguments</key>
  <array>
    <string>__PYTHON_BIN__</string>
    <string>__INSTALL_DIR__/resource_logger.py</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
    <key>Crashed</key>
    <true/>
  </dict>

  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>__HOME__/.omlx-resource-monitor.log</string>

  <key>StandardErrorPath</key>
  <string>__HOME__/.omlx-resource-monitor.log</string>

  <key>WorkingDirectory</key>
  <string>__HOME__</string>
</dict>
</plist>
